---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Hung-Su</h1>
			<p>This is my personal site, where I write about software engineering and other things I'm thinking about.</p>
			<p>
				Take a look at my <a href="/blog">blog</a> or read more <a href="/about">about me</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
