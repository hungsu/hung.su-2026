---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import MagazineSiteNav from '../../components/MagazineSiteNav.astro';
import MagazineFooter from '../../components/MagazineFooter.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const reviews = (await getCollection('reviews')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Reviews" description="Film reviews and thoughts" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Source+Sans+3:wght@300;400;600&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--mag-bg: #0f1923;
				--mag-bg-alt: #172231;
				--mag-fg: #e8f0f0;
				--mag-fg-muted: #7a9aaa;
				--mag-accent: #00b4a6;
				--mag-accent-light: #0a2028;
				--mag-border: #1e3040;
				--mag-font-display: 'Playfair Display', serif;
				--mag-font-body: 'Source Sans 3', sans-serif;
			}

			html,
			body {
				background: var(--mag-bg);
			}
			body {
				color: var(--mag-fg);
				font-family: var(--mag-font-body);
			}
			body :global(a) {
				font-family: inherit;
				text-shadow: none;
			}

			.content-wrap {
				padding: 0 2rem;
			}
			.section {
				padding: 3rem 0;
				border-bottom: 1px solid var(--mag-border);
			}
			.section:last-child {
				border-bottom: none;
			}
			.section-label {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.section-label h2 {
				font-family: var(--mag-font-display);
				font-size: 1.4rem;
				font-weight: 700;
				color: var(--mag-fg);
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--mag-border);
			}

			.card-row {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 2rem;
			}
			.review-card {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.review-card:hover .card-title {
				color: var(--mag-accent);
			}
			.card-img {
				aspect-ratio: 2/3;
				background: var(--mag-bg-alt);
				margin-bottom: 0.75rem;
				overflow: hidden;
			}
			.card-img :global(img),
			.card-img svg {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.card-kicker {
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--mag-accent);
				margin-bottom: 0.25rem;
			}
			.card-title {
				font-family: var(--mag-font-display);
				font-size: 1.1rem;
				line-height: 1.3;
				margin-bottom: 0.35rem;
				transition: color 0.2s;
				color: var(--mag-fg);
			}
			.card-score {
				font-size: 0.78rem;
				color: var(--mag-fg-muted);
			}
			.card-score strong {
				color: var(--mag-accent);
			}

			main {
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: [full-start] minmax(1rem, 1fr) [wide-start] minmax(0, 15ch) [content-start] minmax(0, 60ch) [content-end] minmax(0, 15ch) [wide-end] minmax(1rem, 1fr) [full-end];
			}
			main > * {
				grid-column: full-start / full-end;
				display: grid;
				grid-template-columns: [full-start] minmax(1rem, 1fr) [wide-start] minmax(0, 15ch) [content-start] minmax(0, 60ch) [content-end] minmax(0, 15ch) [wide-end] minmax(1rem, 1fr) [full-end];
			}
			main > * > * {
				grid-column: content-start / content-end;
			}

			@media (max-width: 480px) {
				.content-wrap {
					padding: 0 1rem;
				}
				.card-row {
					grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
				}
			}
		</style>
	</head>
	<body>
		<MagazineSiteNav active="reviews" />

		<main>
			<div class="content-wrap wide">
				<section class="section">
					<div class="section-label">
						<h2>Film Reviews</h2>
					</div>
					<div class="card-row">
						{
							reviews.map((review) => (
								<a href={`/reviews/${review.id}/`} class="review-card">
									<div class="card-img">
										{review.data.backgroundImage ? (
											<Image
												width={220}
												height={330}
												src={review.data.backgroundImage}
												alt={review.data.title}
											/>
										) : review.data.heroImage ? (
											<Image width={220} height={330} src={review.data.heroImage} alt={review.data.title} />
										) : (
											<svg viewBox="0 0 16 9" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
												<rect width="16" height="9" fill="#172231" />
												<text
													x="8"
													y="4.5"
													dominant-baseline="middle"
													text-anchor="middle"
													font-family="Playfair Display"
													font-size="1.4"
													fill="#00b4a6"
													opacity="0.4"
												>
													{review.data.title}
												</text>
											</svg>
										)}
									</div>
									{review.data.year && <div class="card-kicker">{review.data.year}</div>}
									<div class="card-title">{review.data.title}</div>
									{review.data.rating != null && (
										<div class="card-score">
											Score: <strong>{review.data.rating.toFixed(1)}/10</strong>
										</div>
									)}
								</a>
							))
						}
					</div>
				</section>
			</div>
		</main>

		<MagazineFooter />
	</body>
</html>