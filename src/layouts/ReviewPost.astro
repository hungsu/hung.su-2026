---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";
import MagazineFooter from "../components/MagazineFooter.astro";
import MagazineSiteNav from "../components/MagazineSiteNav.astro";

type Props = CollectionEntry<"reviews">["data"];

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    year,
    rating,
    tmdbId,
    verdict,
} = Astro.props;
const tmdbUrl = tmdbId ? `https://www.themoviedb.org/movie/${tmdbId}` : null;
const stars = rating != null ? Math.round((rating / 10) * 5) : null;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Source+Sans+3:wght@300;400;600&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --mag-bg: #0f1923;
                --mag-bg-alt: #172231;
                --mag-fg: #e8f0f0;
                --mag-fg-muted: #7a9aaa;
                --mag-accent: #00b4a6;
                --mag-accent-light: #0d1c28;
                --mag-border: #1e3040;
                --mag-font-display: "Playfair Display", serif;
                --mag-font-body: "Source Sans 3", sans-serif;
            }

            html,
            body {
                background: var(--mag-bg);
            }
            body {
                color: var(--mag-fg);
                font-family: var(--mag-font-body);
                line-height: 1.7;
            }
            body :global(a) {
                font-family: inherit;
                text-shadow: none;
            }

            /* ── PAGE: poster column + reading column ── */
            .page {
                display: grid;
                grid-template-columns: 320px 1fr;
            }

            /* ── POSTER COLUMN (left, sticky) ── */
            .poster-col {
                position: sticky;
                top: 0;
                height: 100vh;
                background: var(--mag-bg-alt);
                border-right: 1px solid var(--mag-border);
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 2rem;
            }
            .poster-frame {
                width: 260px;
                aspect-ratio: 2/3;
                box-shadow:
                    0 20px 60px rgba(0, 0, 0, 0.5),
                    0 0 0 1px rgba(0, 180, 166, 0.15);
                margin-bottom: 1.5rem;
                overflow: hidden;
            }
            .poster-frame :global(img),
            .poster-frame svg {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }
            .poster-stats {
                width: 100%;
                max-width: 260px;
            }
            .poster-stat {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.4rem 0;
                font-size: 0.78rem;
                border-bottom: 1px solid var(--mag-border);
            }
            .poster-stat:last-child {
                border-bottom: none;
            }
            .poster-stat-label {
                color: var(--mag-fg-muted);
                font-weight: 300;
                letter-spacing: 0.06em;
                text-transform: uppercase;
            }
            .poster-stat-value {
                color: var(--mag-fg);
                font-weight: 600;
            }
            .poster-stat-value a {
                color: var(--mag-accent);
            }
            .poster-stat-verdict {
                margin-top: 0.25rem;
                padding-top: 0.6rem;
            }
            .verdict-pill {
                display: inline-block;
                background: var(--mag-accent);
                color: var(--mag-bg);
                font-size: 0.62rem;
                font-weight: 700;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                padding: 0.2rem 0.55rem;
                border-radius: 999px;
            }

            /* ── CONTENT COLUMN (right) ── */
            .content-col {
                border-left: 1px solid var(--mag-border);
            }
            .article-header {
                padding: 3rem 3rem 2rem;
                border-bottom: 1px solid var(--mag-border);
            }
            .article-kicker {
                font-size: 0.72rem;
                font-weight: 600;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: var(--mag-accent);
                margin-bottom: 0.75rem;
            }
            .article-title {
                font-family: var(--mag-font-display);
                font-size: clamp(2.5rem, 5vw, 4rem);
                line-height: 1;
                font-weight: 900;
                margin-bottom: 0.5rem;
                color: var(--mag-fg);
            }
            .article-subtitle {
                font-family: var(--mag-font-display);
                font-style: italic;
                font-size: 1.15rem;
                color: var(--mag-fg-muted);
                margin-bottom: 1.5rem;
            }
            .article-meta {
                display: flex;
                gap: 2rem;
                flex-wrap: wrap;
                font-size: 0.78rem;
                color: var(--mag-fg-muted);
            }
            .article-meta a {
                color: var(--mag-accent);
            }

            .review-text {
                padding: 2.5rem 3rem 4rem;
                max-width: 64ch;
            }
            .review-text :global(p) {
                font-size: 1.05rem;
                line-height: 1.85;
                margin-bottom: 1.5rem;
                color: #c8d8d8;
            }
            .review-text :global(p:first-of-type::first-letter) {
                font-family: var(--mag-font-display);
                font-size: 4.5rem;
                float: left;
                line-height: 0.8;
                padding-right: 0.5rem;
                padding-top: 0.15rem;
                color: var(--mag-accent);
                font-weight: 900;
            }
            .review-text :global(h2) {
                font-family: var(--mag-font-display);
                font-size: 1.6rem;
                font-weight: 700;
                margin: 2.5rem 0 1rem;
                color: var(--mag-fg);
            }
            .review-text :global(blockquote) {
                border-left: 3px solid var(--mag-accent);
                padding: 1rem 1.5rem;
                background: var(--mag-accent-light);
                font-family: var(--mag-font-display);
                font-size: 1.25rem;
                font-style: italic;
                line-height: 1.4;
                margin: 0 0 1.5rem;
            }
            .review-text :global(img) {
                width: 100%;
                border-radius: 4px;
            }
            .review-text :global(a) {
                color: var(--mag-accent);
            }

            /* ── RESPONSIVE ── */
            @media (max-width: 700px) {
                .page {
                    grid-template-columns: 1fr;
                }
                .poster-col {
                    position: relative;
                    height: auto;
                    padding: 1.5rem;
                    flex-direction: row;
                    gap: 1.25rem;
                    flex-wrap: wrap;
                    align-items: center;
                    justify-content: center;
                    border-right: none;
                    border-bottom: 1px solid var(--mag-border);
                }
                .poster-frame {
                    width: 140px;
                    margin-bottom: 0;
                }
                .poster-stats {
                    max-width: 180px;
                }
                .content-col {
                    border-left: none;
                }
                .article-header {
                    padding: 2rem 1.5rem 1.5rem;
                }
                .review-text {
                    padding: 2rem 1.5rem;
                }
            }
        </style>
    </head>
    <body>
        <MagazineSiteNav active="reviews" />

        <main>
            <div class="page full-bleed">
                <aside class="poster-col">
                    <div class="poster-frame">
                        {
                            heroImage ? (
                                <Image
                                    width={400}
                                    height={600}
                                    src={heroImage}
                                    alt={title}
                                />
                            ) : (
                                <svg
                                    viewBox="0 0 2 3"
                                    xmlns="http://www.w3.org/2000/svg"
                                    preserveAspectRatio="xMidYMid slice"
                                >
                                    <rect width="2" height="3" fill="#0d1c28" />
                                    <text
                                        x="1"
                                        y="1.5"
                                        dominant-baseline="middle"
                                        text-anchor="middle"
                                        font-family="Playfair Display"
                                        font-size="0.16"
                                        fill="#00b4a6"
                                        opacity="0.5"
                                        font-weight="900"
                                    >
                                        {title}
                                    </text>
                                </svg>
                            )
                        }
                    </div>
                    <div class="poster-stats">
                        {
                            stars != null && (
                                <div class="poster-stat">
                                    <span class="poster-stat-label">
                                        Rating
                                    </span>
                                    <span class="poster-stat-value">
                                        {"★".repeat(stars) + "☆".repeat(5 - stars)}
                                    </span>
                                </div>
                            )
                        }
                        {
                            year && (
                                <div class="poster-stat">
                                    <span class="poster-stat-label">Year</span>
                                    <span class="poster-stat-value">
                                        {year}
                                    </span>
                                </div>
                            )
                        }
                        {
                            tmdbUrl && (
                                <div class="poster-stat">
                                    <span class="poster-stat-label">TMDb</span>
                                    <span class="poster-stat-value">
                                        <a
                                            href={tmdbUrl}
                                            target="_blank"
                                            rel="noopener"
                                        >
                                            View →
                                        </a>
                                    </span>
                                </div>
                            )
                        }
                        {
                            verdict && (
                                <div class="poster-stat poster-stat-verdict">
                                    <span class="poster-stat-label">
                                        Verdict
                                    </span>
                                    <span class="verdict-pill">{verdict}</span>
                                </div>
                            )
                        }
                    </div>
                </aside>

                <div class="content-col">
                    <header class="article-header">
                        <div class="article-kicker">Film Review</div>
                        <h1 class="article-title">{title}</h1>
                        <p class="article-subtitle">{description}</p>
                        <div class="article-meta">
                            <span>
                                <FormattedDate date={pubDate} />
                            </span>
                            {
                                updatedDate && (
                                    <span>
                                        Updated{" "}
                                        <FormattedDate date={updatedDate} />
                                    </span>
                                )
                            }
                        </div>
                    </header>

                    <article class="review-text">
                        <slot />
                    </article>
                </div>
            </div>
        </main>

        <MagazineFooter />
    </body>
</html>
