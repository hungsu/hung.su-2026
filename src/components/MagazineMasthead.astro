---
const today = new Date().toLocaleDateString('en-US', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<header class="masthead">
	<div class="masthead-tagline">Software · Film · Writing</div>
	<a href="/" class="masthead-logo">hung<em>.</em>su</a>
	<div class="masthead-date">{today}</div>
</header>

<style>
	.masthead {
		background: var(--mag-bg-alt);
		padding: 1.5rem 2rem 1rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.masthead-tagline {
		font-size: 0.7rem;
		font-weight: 300;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--mag-fg-muted);
	}
	.masthead-logo {
		flex: 1;
		font-family: var(--mag-font-display);
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 900;
		letter-spacing: -0.02em;
		text-align: center;
		text-decoration: none;
		color: var(--mag-fg);
	}
	.masthead-logo em {
		color: var(--mag-accent);
		font-style: normal;
	}
	.masthead-date {
		text-align: right;
		font-size: 0.7rem;
		font-weight: 300;
		letter-spacing: 0.08em;
		color: var(--mag-fg-muted);
	}

	@media (max-width: 480px) {
		.masthead-tagline,
		.masthead-date {
			display: none;
		}
	}
</style>
